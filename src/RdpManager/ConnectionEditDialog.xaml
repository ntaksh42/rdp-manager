<Window x:Class="RdpManager.ConnectionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Connection" SizeToContent="Height" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        UseLayoutRounding="True"
        Background="{DynamicResource WindowBg}"
        TextElement.Foreground="{DynamicResource TextFg}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <!-- Name (folder/connection common) -->
            <TextBlock Text="Display name" Margin="0,0,0,2"/>
            <TextBox x:Name="NameBox" Padding="4,3" Margin="0,0,0,10"/>

            <!-- Connection only -->
            <StackPanel x:Name="ConnPanel">
                <TextBlock Text="Protocol" Margin="0,0,0,2"/>
                <ComboBox x:Name="ProtocolBox" Margin="0,0,0,10">
                    <ComboBoxItem Content="RDP" Tag="RDP"/>
                    <ComboBoxItem Content="SSH" Tag="SSH"/>
                    <ComboBoxItem Content="Telnet" Tag="Telnet"/>
                    <ComboBoxItem Content="VNC" Tag="VNC"/>
                </ComboBox>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Host / IP" Margin="0,0,0,2"/>
                        <TextBox x:Name="HostBox" Padding="4,3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Port" Margin="0,0,0,2"/>
                        <TextBox x:Name="PortBox" Padding="4,3"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Comment" Margin="0,0,0,2"/>
                <TextBox x:Name="CommentBox" Padding="4,3" Margin="0,0,0,10"/>

                <TextBlock Text="Credentials" Margin="0,0,0,2"/>
                <ComboBox x:Name="CredModeBox" Margin="0,0,0,8" SelectionChanged="OnCredModeChanged">
                    <ComboBoxItem Content="Enter directly" Tag="direct"/>
                    <ComboBoxItem Content="Use a profile" Tag="profile"/>
                    <ComboBoxItem Content="Windows Credential Manager" Tag="winCred"/>
                    <ComboBoxItem Content="Inherit from parent folder" Tag="inheritFromParent"/>
                </ComboBox>

                <StackPanel x:Name="DirectCredPanel">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Domain" Margin="0,0,0,2"/>
                            <TextBox x:Name="DomainBox" Padding="4,3"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Username" Margin="0,0,0,2"/>
                            <TextBox x:Name="UserBox" Padding="4,3"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Password" Margin="0,0,0,2"/>
                    <PasswordBox x:Name="PassBox" Padding="4,3" Margin="0,0,0,10"/>
                </StackPanel>

                <StackPanel x:Name="ProfileCredPanel">
                    <TextBlock Text="Profile" Margin="0,0,0,2"/>
                    <ComboBox x:Name="ProfileBox" Margin="0,0,0,10" DisplayMemberPath="Name"/>
                </StackPanel>

                <TextBlock Text="Pre-connect command (optional, {host} {port} {user})" Margin="0,0,0,2"/>
                <TextBox x:Name="PreCmdBox" Padding="4,3" Margin="0,0,0,8"/>
                <TextBlock Text="Post-disconnect command (optional)" Margin="0,0,0,2"/>
                <TextBox x:Name="PostCmdBox" Padding="4,3" Margin="0,0,0,4"/>
            </StackPanel>

            <!-- Display/RDP settings (defaults on folders, inheritable on connections) -->
            <StackPanel x:Name="SettingsPanel">
                <CheckBox x:Name="InheritSettingsChk" Content="Inherit display settings from parent folder"
                          Margin="0,4,0,8" Click="OnInheritSettingsChanged"/>
                <StackPanel x:Name="SettingsDetail">
                    <TextBlock Text="RDP Gateway (optional)" Margin="0,0,0,2"/>
                    <TextBox x:Name="GatewayBox" Padding="4,3" Margin="0,0,0,10"/>
                    <TextBlock Text="Server authentication" Margin="0,0,0,2"/>
                    <ComboBox x:Name="AuthLevelBox" Margin="0,0,0,10">
                        <ComboBoxItem Content="Require certificate check (recommended)" Tag="2"/>
                        <ComboBoxItem Content="Warn on mismatch" Tag="1"/>
                        <ComboBoxItem Content="No check (insecure)" Tag="0"/>
                    </ComboBox>
                    <WrapPanel Margin="0,0,0,4">
                        <CheckBox x:Name="FullscreenChk" Content="Open full screen" Margin="0,0,16,6"/>
                        <CheckBox x:Name="SmartSizingChk" Content="Smart sizing" Margin="0,0,16,6"/>
                        <CheckBox x:Name="ClipboardChk" Content="Share clipboard" Margin="0,0,16,6"/>
                        <CheckBox x:Name="DrivesChk" Content="Share drives" Margin="0,0,16,6"/>
                    </WrapPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="84" Padding="0,4" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="Cancel" Width="84" Padding="0,4" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
