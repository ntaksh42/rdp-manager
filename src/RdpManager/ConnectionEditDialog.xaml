<Window x:Class="RdpManager.ConnectionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="接続の編集" SizeToContent="Height" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        UseLayoutRounding="True">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <!-- 名前（フォルダ・接続共通）-->
            <TextBlock Text="表示名" Margin="0,0,0,2"/>
            <TextBox x:Name="NameBox" Padding="4,3" Margin="0,0,0,10"/>

            <!-- 接続専用 -->
            <StackPanel x:Name="ConnPanel">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="ホスト名 / IP" Margin="0,0,0,2"/>
                        <TextBox x:Name="HostBox" Padding="4,3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="ポート" Margin="0,0,0,2"/>
                        <TextBox x:Name="PortBox" Padding="4,3"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="コメント" Margin="0,0,0,2"/>
                <TextBox x:Name="CommentBox" Padding="4,3" Margin="0,0,0,10"/>

                <TextBlock Text="資格情報" Margin="0,0,0,2"/>
                <ComboBox x:Name="CredModeBox" Margin="0,0,0,8" SelectionChanged="OnCredModeChanged">
                    <ComboBoxItem Content="直接入力" Tag="direct"/>
                    <ComboBoxItem Content="プロファイルを使用" Tag="profile"/>
                    <ComboBoxItem Content="Windows 資格情報マネージャー" Tag="winCred"/>
                    <ComboBoxItem Content="親フォルダから継承" Tag="inheritFromParent"/>
                </ComboBox>

                <StackPanel x:Name="DirectCredPanel">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="ドメイン" Margin="0,0,0,2"/>
                            <TextBox x:Name="DomainBox" Padding="4,3"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="ユーザー名" Margin="0,0,0,2"/>
                            <TextBox x:Name="UserBox" Padding="4,3"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="パスワード" Margin="0,0,0,2"/>
                    <PasswordBox x:Name="PassBox" Padding="4,3" Margin="0,0,0,10"/>
                </StackPanel>

                <StackPanel x:Name="ProfileCredPanel">
                    <TextBlock Text="プロファイル" Margin="0,0,0,2"/>
                    <ComboBox x:Name="ProfileBox" Margin="0,0,0,10" DisplayMemberPath="Name"/>
                </StackPanel>

                <TextBlock Text="接続前コマンド（任意, {host} {port} {user} 可）" Margin="0,0,0,2"/>
                <TextBox x:Name="PreCmdBox" Padding="4,3" Margin="0,0,0,8"/>
                <TextBlock Text="切断後コマンド（任意）" Margin="0,0,0,2"/>
                <TextBox x:Name="PostCmdBox" Padding="4,3" Margin="0,0,0,4"/>
            </StackPanel>

            <!-- 表示/RDP 設定（フォルダでは既定値、接続では継承可）-->
            <StackPanel x:Name="SettingsPanel">
                <CheckBox x:Name="InheritSettingsChk" Content="表示設定を親フォルダから継承する"
                          Margin="0,4,0,8" Click="OnInheritSettingsChanged"/>
                <StackPanel x:Name="SettingsDetail">
                    <TextBlock Text="RDP ゲートウェイ（任意）" Margin="0,0,0,2"/>
                    <TextBox x:Name="GatewayBox" Padding="4,3" Margin="0,0,0,10"/>
                    <WrapPanel Margin="0,0,0,4">
                        <CheckBox x:Name="FullscreenChk" Content="全画面で開く" Margin="0,0,16,6"/>
                        <CheckBox x:Name="SmartSizingChk" Content="スマートサイジング" Margin="0,0,16,6"/>
                        <CheckBox x:Name="ClipboardChk" Content="クリップボード共有" Margin="0,0,16,6"/>
                        <CheckBox x:Name="DrivesChk" Content="ドライブ共有" Margin="0,0,16,6"/>
                    </WrapPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="84" Padding="0,4" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="キャンセル" Width="84" Padding="0,4" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
