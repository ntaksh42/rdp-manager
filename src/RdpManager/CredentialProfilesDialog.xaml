<Window x:Class="RdpManager.CredentialProfilesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Credential Profiles" Height="380" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" UseLayoutRounding="True"
        Background="{DynamicResource WindowBg}"
        TextElement.Foreground="{DynamicResource TextFg}">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="ProfileList" Grid.Row="0" Grid.Column="0" Margin="0,0,10,0"
                 DisplayMemberPath="Name" SelectionChanged="OnSelect"/>

        <StackPanel Grid.Row="0" Grid.Column="1">
            <TextBlock Text="Profile name" Margin="0,0,0,2"/>
            <TextBox x:Name="NameBox" Padding="4,3" Margin="0,0,0,8"/>
            <TextBlock Text="Domain" Margin="0,0,0,2"/>
            <TextBox x:Name="DomainBox" Padding="4,3" Margin="0,0,0,8"/>
            <TextBlock Text="Username" Margin="0,0,0,2"/>
            <TextBox x:Name="UserBox" Padding="4,3" Margin="0,0,0,8"/>
            <TextBlock Text="Password" Margin="0,0,0,2"/>
            <PasswordBox x:Name="PassBox" Padding="4,3" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="New" Width="70" Padding="0,4" Margin="0,0,6,0" Click="OnNew"/>
                <Button Content="Save" Width="70" Padding="0,4" Margin="0,0,6,0" Click="OnSaveProfile"/>
                <Button Content="Delete" Width="70" Padding="0,4" Click="OnDelete"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Width="90" Padding="0,4" IsCancel="True" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
