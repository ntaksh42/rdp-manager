<Window x:Class="RdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RdpManager.ViewModels"
        Title="RdpManager" Height="640" Width="960"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="TreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="保存先フォルダを開く" Click="OnOpenStoreFolder"/>
                <Separator/>
                <MenuItem Header="終了" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="編集(_E)">
                <MenuItem Header="新規フォルダ" Click="OnNewFolder"/>
                <MenuItem Header="新規接続" Click="OnNewConnection"/>
                <MenuItem Header="編集…" Click="OnEditNode"/>
                <MenuItem Header="削除" Click="OnDeleteNode"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報" Click="OnAbout"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button Content="📁 新規フォルダ" Click="OnNewFolder"/>
            <Button Content="🖥️ 新規接続" Click="OnNewConnection"/>
            <Separator/>
            <Button Content="✎ 編集" Click="OnEditNode"/>
            <Button Content="🗑 削除" Click="OnDeleteNode"/>
            <Separator/>
            <Button Content="▶ 接続" Command="{Binding ConnectCommand}"/>
        </ToolBar>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem><TextBlock Text="{Binding StatusText}"/></StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 接続ツリー -->
            <DockPanel Grid.Column="0" Background="#FAFAFA">
                <Grid DockPanel.Dock="Top" Margin="6">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="4,3"/>
                    <TextBlock Text="🔍 接続を検索…" Foreground="#9E9E9E" Margin="8,0"
                               IsHitTestVisible="False" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TreeView x:Name="Tree" BorderThickness="0" Background="Transparent"
                          ItemsSource="{Binding RootNodes}"
                          ItemContainerStyle="{StaticResource TreeItemStyle}"
                          SelectedItemChanged="OnTreeSelectionChanged"
                          MouseDoubleClick="OnTreeDoubleClick">
                    <TreeView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="接続" Click="OnConnectMenu"/>
                            <Separator/>
                            <MenuItem Header="新規フォルダ" Click="OnNewFolder"/>
                            <MenuItem Header="新規接続" Click="OnNewConnection"/>
                            <MenuItem Header="編集…" Click="OnEditNode"/>
                            <MenuItem Header="削除" Click="OnDeleteNode"/>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Glyph}" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding HostDisplay}" Foreground="#9E9E9E"
                                           Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" VerticalAlignment="Stretch"
                          HorizontalAlignment="Center" Background="#E0E0E0"/>

            <!-- 右ペイン -->
            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="クイック接続:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="QuickHostBox" Width="220" VerticalContentAlignment="Center"
                                 Padding="4,2" KeyDown="OnQuickConnectKeyDown"/>
                        <Button Content="接続" Margin="6,0,0,0" Padding="14,2" Click="OnQuickConnect"/>
                    </StackPanel>
                </Border>

                <!-- 詳細 / 空状態 -->
                <Grid Margin="20">
                    <!-- 接続未選択 -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding NoConnectionSelected, Converter={StaticResource BoolToVis}}">
                        <TextBlock x:Name="EmptyHint" Text="左のツリーから接続を選ぶと詳細が表示されます"
                                   Foreground="#9E9E9E" FontSize="14" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- 接続選択時の詳細 -->
                    <StackPanel Visibility="{Binding HasConnectionSelected, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding SelectedNode.Name}" FontSize="22" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedNode.HostDisplay}" Foreground="#666" FontSize="14" Margin="0,2,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ユーザー" Foreground="#888" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedNode.Username}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="ドメイン" Foreground="#888" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedNode.Domain}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="資格情報" Foreground="#888" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedNode.CredentialMode}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="ゲートウェイ" Foreground="#888" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedNode.Gateway}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="コメント" Foreground="#888" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedNode.Comment}" TextWrapping="Wrap" Margin="0,3"/>
                        </Grid>

                        <Button Content="▶ 接続" Command="{Binding ConnectCommand}"
                                HorizontalAlignment="Left" Padding="24,8" Margin="0,24,0,0"
                                FontSize="14" Background="#1976D2" Foreground="White" BorderThickness="0"/>
                        <Button Content="✎ この接続を編集" Click="OnEditNode"
                                HorizontalAlignment="Left" Padding="14,4" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
