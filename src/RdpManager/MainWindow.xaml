<Window x:Class="RdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RdpManager.ViewModels"
        Title="RdpManager" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}"
        TextElement.Foreground="{DynamicResource TextFg}"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="TreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel>
        <Menu x:Name="MainMenu" DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Import CSV…" Click="OnImportCsv"/>
                <MenuItem Header="Import .rdp…" Click="OnImportRdp"/>
                <MenuItem Header="Export CSV…" Click="OnExportCsv"/>
                <Separator/>
                <MenuItem Header="Open Data Folder" Click="OnOpenStoreFolder"/>
                <Separator/>
                <MenuItem Header="Exit" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="New Folder" Click="OnNewFolder"/>
                <MenuItem Header="New Connection" Click="OnNewConnection"/>
                <MenuItem Header="Add by Pattern…" Click="OnPatternAdd"/>
                <MenuItem Header="Edit…" Click="OnEditNode"/>
                <MenuItem Header="Delete" Click="OnDeleteNode"/>
                <Separator/>
                <MenuItem Header="Manage Credential Profiles…" Click="OnManageProfiles"/>
            </MenuItem>
            <MenuItem Header="_Session">
                <MenuItem Header="Connect (in this window)" Click="OnConnectEmbedded"/>
                <MenuItem Header="Open in External Window (mstsc)" Click="OnConnectExternal"/>
                <Separator/>
                <MenuItem Header="Send Keys">
                    <MenuItem Header="How to send Ctrl+Alt+Del" Click="OnSendCtrlAltDel"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Sessions (Dashboard)…" Click="OnSessionDashboard"/>
                <MenuItem Header="Refresh Host Status" Click="OnRefreshStatus"/>
                <Separator/>
                <MenuItem Header="Toggle Full Screen" InputGestureText="F11 / Ctrl+Alt+Pause" Click="OnToggleFullscreenMenu"/>
                <MenuItem x:Name="FullscreenSpanItem" Header="Span All Monitors in Full Screen" IsCheckable="True" Click="OnToggleFullscreenSpan"/>
                <MenuItem x:Name="PerformanceModeItem" Header="Optimize for Performance" IsCheckable="True" Click="OnTogglePerformanceMode"/>
                <MenuItem x:Name="DarkModeItem" Header="Dark Mode" IsCheckable="True" Click="OnToggleDarkMode"/>
                <MenuItem x:Name="RestoreSessionsItem" Header="Restore Sessions on Startup" IsCheckable="True" Click="OnToggleRestoreSessions"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Check for Updates…" Click="OnCheckUpdate"/>
                <MenuItem Header="About" Click="OnAbout"/>
            </MenuItem>
        </Menu>

        <ToolBar x:Name="MainToolBar" DockPanel.Dock="Top">
            <Button Content="📁 New Folder" Click="OnNewFolder"/>
            <Button Content="🖥️ New Connection" Click="OnNewConnection"/>
            <Separator/>
            <Button Content="✎ Edit" Click="OnEditNode"/>
            <Button Content="🗑 Delete" Click="OnDeleteNode"/>
            <Separator/>
            <Button Content="▶ Connect" Click="OnConnectEmbedded"/>
        </ToolBar>

        <StatusBar x:Name="MainStatus" DockPanel.Dock="Bottom">
            <StatusBarItem><TextBlock Text="{Binding StatusText}"/></StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="280" MinWidth="200"/>
                <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Connection tree -->
            <DockPanel x:Name="TreePane" Grid.Column="0" Background="{DynamicResource PanelBg}">
                <Grid DockPanel.Dock="Top" Margin="6">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="4,3"/>
                    <TextBlock Text="🔍 Search connections…" Foreground="#9E9E9E" Margin="8,0"
                               IsHitTestVisible="False" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Border DockPanel.Dock="Top" Margin="6,0,6,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding QuickAccess.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="★ Quick Access" Foreground="#888" FontSize="11" Margin="2,0,0,2"/>
                        <ListBox x:Name="QuickList" ItemsSource="{Binding QuickAccess}" MaxHeight="150"
                                 BorderThickness="0" Background="Transparent"
                                 MouseDoubleClick="OnQuickAccessDouble">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Glyph}" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding HostDisplay}" Foreground="#9E9E9E"
                                                   Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <TreeView x:Name="Tree" BorderThickness="0" Background="Transparent"
                          ItemsSource="{Binding RootNodes}"
                          ItemContainerStyle="{StaticResource TreeItemStyle}"
                          SelectedItemChanged="OnTreeSelectionChanged"
                          MouseDoubleClick="OnTreeDoubleClick"
                          AllowDrop="True"
                          PreviewMouseLeftButtonDown="OnTreeMouseDown"
                          PreviewMouseMove="OnTreeMouseMove"
                          DragOver="OnTreeDragOver"
                          Drop="OnTreeDrop">
                    <TreeView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Connect (in this window)" Click="OnConnectEmbedded"/>
                            <MenuItem Header="Open in Right Pane (Split)" Click="OnConnectRight"/>
                            <MenuItem Header="Open in External Window (mstsc)" Click="OnConnectExternal"/>
                            <MenuItem Header="Toggle Favorite" Click="OnToggleFavorite"/>
                            <Separator/>
                            <MenuItem Header="Connect All in Folder" Click="OnConnectAll"/>
                            <MenuItem Header="Disconnect All in Folder" Click="OnDisconnectAll"/>
                            <Separator/>
                            <MenuItem Header="New Folder" Click="OnNewFolder"/>
                            <MenuItem Header="New Connection" Click="OnNewConnection"/>
                            <MenuItem Header="Edit…" Click="OnEditNode"/>
                            <MenuItem Header="Delete" Click="OnDeleteNode"/>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,4,0" VerticalAlignment="Center"
                                         Visibility="{Binding IsConnection, Converter={StaticResource BoolToVis}}">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Transparent"/>
                                            <Setter Property="Stroke" Value="#BBB"/>
                                            <Setter Property="StrokeThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Up">
                                                    <Setter Property="Fill" Value="LimeGreen"/>
                                                    <Setter Property="Stroke" Value="LimeGreen"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Down">
                                                    <Setter Property="Fill" Value="OrangeRed"/>
                                                    <Setter Property="Stroke" Value="OrangeRed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding Glyph}" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding HostDisplay}" Foreground="#9E9E9E"
                                           Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>

            <GridSplitter x:Name="Splitter" Grid.Column="1" Width="4" VerticalAlignment="Stretch"
                          HorizontalAlignment="Center" Background="#E0E0E0"/>

            <!-- Right pane: session tabs -->
            <DockPanel Grid.Column="2">
                <Border x:Name="QuickBar" DockPanel.Dock="Top" Background="#F0F0F0" Padding="8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Quick Connect:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="QuickHostBox" Width="220" VerticalContentAlignment="Center"
                                 Padding="4,2" KeyDown="OnQuickConnectKeyDown"/>
                        <Button Content="Connect" Margin="6,0,0,0" Padding="14,2" Click="OnQuickConnect"/>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="RightSplitterCol" Width="0"/>
                        <ColumnDefinition x:Name="RightCol" Width="0"/>
                    </Grid.ColumnDefinitions>
                    <TabControl x:Name="SessionTabs" Grid.Column="0"/>
                    <GridSplitter x:Name="RightSplitter" Grid.Column="1" Width="4"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Background="#E0E0E0" Visibility="Collapsed"/>
                    <TabControl x:Name="SessionTabsRight" Grid.Column="2"/>
                    <TextBlock x:Name="EmptyHint" Grid.Column="0"
                               Text="Double-click a connection in the tree to open it here.&#x0a;(Right-click &#8594; Open in Right Pane for split view)"
                               Foreground="#9E9E9E" FontSize="14" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
