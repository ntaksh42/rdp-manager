<Window x:Class="RdpManager.SessionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="セッション一覧" Height="360" Width="460"
        WindowStartupLocation="CenterOwner" UseLayoutRounding="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="ダブルクリックで対象セッションへ切り替えます" Foreground="#888" Margin="0,0,0,8"/>
        <ListBox x:Name="List" Grid.Row="1" MouseDoubleClick="OnActivate">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center" Fill="{Binding StateColor}"/>
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Host}" Foreground="#888" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StateText}" Foreground="#888" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
