<Window x:Class="RdpManager.Views.QuickSwitchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Switch"
        WindowStyle="None" ResizeMode="NoResize" Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Width="480" Height="380"
        UseLayoutRounding="True"
        Background="{DynamicResource ControlBorder}"
        TextElement.Foreground="{DynamicResource TextFg}"
        PreviewKeyDown="OnPreviewKeyDown">
    <Border Margin="1" Background="{DynamicResource WindowBg}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBox x:Name="FilterBox" Grid.Row="0" Padding="6,5" Margin="0,0,0,8"
                     TextChanged="OnFilterChanged"/>
            <ListBox x:Name="ResultsList" Grid.Row="1" MouseDoubleClick="OnListDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,3">
                            <TextBlock Text="{Binding Marker}" Foreground="LimeGreen" Width="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding HostDisplay}" Foreground="{DynamicResource SubtleFg}"
                                       Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
